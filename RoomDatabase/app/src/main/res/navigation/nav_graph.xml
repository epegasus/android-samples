<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/fragmentHome">

    <fragment
        android:id="@+id/fragmentHome"
        android:name="com.sohaib.roomdatabase.presentation.fragments.FragmentHome"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_fragmentHome_to_fragmentAdd"
            app:destination="@id/fragmentAdd" />
    </fragment>
    <fragment
        android:id="@+id/fragmentAdd"
        android:name="com.sohaib.roomdatabase.presentation.fragments.FragmentAddRecord"
        android:label="Add Record"
        tools:layout="@layout/fragment_add_record">
        <argument
            android:name="note"
            android:defaultValue="@null"
            app:argType="com.sohaib.roomdatabase.data.dataSource.model.Note"
            app:nullable="true" />
    </fragment>
</navigation>